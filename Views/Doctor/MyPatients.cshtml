@model List<Patient>
@{ ViewData["Title"] = "My Patients"; }
<div class="page-header"><div class="ph-left"><div class="breadcrumb"><span>Doctor</span><i class="fas fa-chevron-right"></i><span>My Patients</span></div><h1 class="ph-title">My Patients</h1></div></div>
<div class="card mb3"><div class="card-body"><form method="get" class="search-bar">
  <div class="sb-input"><i class="fas fa-search"></i><input name="search" value="@ViewBag.Search" class="fi" placeholder="Search…" style="width:280px"/></div>
  <button type="submit" class="btn btn-primary btn-sm">Search</button>
  @if(!string.IsNullOrEmpty(ViewBag.Search as string)){<a asp-action="MyPatients" class="btn btn-outline btn-sm">Clear</a>}
</form></div></div>
<div class="card"><div class="table-wrap"><table class="dtable">
  <thead><tr><th>ID</th><th>Name</th><th>Age</th><th>Contact</th><th>Status</th><th>Actions</th></tr></thead>
  <tbody>
  @foreach(var p in Model){<tr>
    <td class="tid">#@p.PatientId</td><td class="fw6">@p.FullName</td><td>@p.Age yr</td><td>@p.ContactNumber</td>
    <td>@if(p.AdmissionStatus==AdmissionStatus.Admitted){<span class="badge b-admitted">Admitted</span>}else{<span class="badge b-registered">Registered</span>}</td>
    <td><a asp-action="PatientDetails" asp-route-id="@p.PatientId" class="btn btn-sm btn-primary">Details</a></td>
  </tr>}
  </tbody>
</table>@if(!Model.Any()){<div class="empty-state"><i class="fas fa-procedures"></i><p>No patients found.</p></div>}
</div></div>
