@model DispenseVM
@{ ViewData["Title"] = "Dispense Medicine"; }
<div class="page-header"><div class="ph-left"><div class="breadcrumb"><a asp-action="Dashboard">Pharmacy</a><i class="fas fa-chevron-right"></i><span>Dispense</span></div><h1 class="ph-title">Dispense Medicine</h1></div></div>
<div class="form-wrap"><div class="card">
  <div class="card-hdr"><i class="fas fa-pills"></i> @Model.MedicineName — @Model.PatientName</div>
  <div class="card-body">
    <form asp-action="Dispense" method="post">@Html.AntiForgeryToken()
      <input type="hidden" asp-for="PrescriptionId"/><input type="hidden" asp-for="MedicineName"/><input type="hidden" asp-for="PatientName"/>
      <div asp-validation-summary="ModelOnly" class="v-errors"></div>
      <div class="form-grid">
        <div class="fg"><label class="fl">Medicine Cost (Rs.) <span class="req">*</span></label><input asp-for="MedicineCost" type="number" step="0.01" class="fi" placeholder="0.00"/><span asp-validation-for="MedicineCost" class="ferr"></span></div>
      </div>
      <div class="btn-row mt2"><button type="submit" class="btn btn-primary"><i class="fas fa-check"></i> Confirm Dispense</button><a asp-action="Dashboard" class="btn btn-outline">Cancel</a></div>
    </form>
  </div>
</div></div>
@section Scripts { @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); } }
