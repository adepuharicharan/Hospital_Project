@model List<Prescription>
@{ ViewData["Title"] = "All Prescriptions"; }
<div class="page-header"><div class="ph-left"><div class="breadcrumb"><span>Pharmacy</span><i class="fas fa-chevron-right"></i><span>All</span></div><h1 class="ph-title">All Prescriptions</h1></div></div>
<div class="card mb3"><div class="card-body"><form method="get" class="search-bar">
  <div class="sb-input"><i class="fas fa-search"></i><input name="search" value="@ViewBag.Search" class="fi" placeholder="Search patient or medicine…" style="width:280px"/></div>
  <button type="submit" class="btn btn-primary btn-sm">Search</button>
</form></div></div>
<div class="card"><div class="table-wrap"><table class="dtable">
  <thead><tr><th>ID</th><th>Patient</th><th>Medicine</th><th>Dosage</th><th>Status</th><th>Cost</th><th>Action</th></tr></thead>
  <tbody>
  @foreach(var r in Model){<tr>
    <td class="tid">#@r.PrescriptionId</td><td class="fw6">@(r.Patient?.FullName??"—")</td><td>@r.MedicineName</td><td class="tsm">@r.Dosage</td>
    <td>@if(r.Status==PrescriptionStatus.Dispensed){<span class="badge b-active">Dispensed</span>}else{<span class="badge b-registered">Prescribed</span>}</td>
    <td>&#x20b9;@r.MedicineCost.ToString("N0")</td>
    <td>@if(r.Status==PrescriptionStatus.Prescribed){<a asp-action="Dispense" asp-route-id="@r.PrescriptionId" class="btn btn-sm btn-primary">Dispense</a>}</td>
  </tr>}
  </tbody>
</table>@if(!Model.Any()){<div class="empty-state"><i class="fas fa-pills"></i><p>No prescriptions found.</p></div>}
</div></div>
