@model List<Patient>
@{ ViewData["Title"] = "Reception Dashboard"; }
<div class="page-header"><div class="ph-left"><h1 class="ph-title">Reception Dashboard</h1><p class="ph-sub">@DateTime.Now.ToString("dddd, dd MMMM yyyy")</p></div>
  <a asp-action="RegisterPatient" class="btn btn-primary"><i class="fas fa-user-plus"></i> Register Patient</a>
</div>
<div class="stats-row">
  <div class="stat-card sc-teal"><div class="sc-icon"><i class="fas fa-clipboard-list"></i></div><div class="sc-info"><div class="sc-val">@ViewBag.Registered</div><div class="sc-lbl">Registered</div></div></div>
  <div class="stat-card sc-green"><div class="sc-icon"><i class="fas fa-bed"></i></div><div class="sc-info"><div class="sc-val">@ViewBag.Admitted</div><div class="sc-lbl">Admitted</div></div></div>
  <div class="stat-card sc-purple"><div class="sc-icon"><i class="fas fa-sign-out-alt"></i></div><div class="sc-info"><div class="sc-val">@ViewBag.Discharged</div><div class="sc-lbl">Discharged</div></div></div>
</div>
<div class="card"><div class="card-hdr"><i class="fas fa-clock"></i> Recent Patients <a asp-action="PatientList" class="btn btn-sm btn-outline ml-auto">View All</a></div>
<div class="table-wrap"><table class="dtable">
  <thead><tr><th>ID</th><th>Name</th><th>Contact</th><th>Doctor</th><th>Status</th><th>Date</th><th>Actions</th></tr></thead>
  <tbody>
  @foreach(var p in Model){<tr>
    <td class="tid">#@p.PatientId</td><td class="fw6">@p.FullName</td><td>@p.ContactNumber</td>
    <td class="tsm">@(p.AssignedDoctor?.FullName??"—")</td>
    <td>@if(p.AdmissionStatus==AdmissionStatus.Admitted){<span class="badge b-admitted">Admitted</span>}else if(p.AdmissionStatus==AdmissionStatus.Discharged){<span class="badge b-discharged">Discharged</span>}else{<span class="badge b-registered">Registered</span>}</td>
    <td class="tsm tm">@p.RegistrationDate.ToString("dd MMM yyyy")</td>
    <td><a asp-action="PatientDetails" asp-route-id="@p.PatientId" class="btn btn-sm btn-outline">View</a></td>
  </tr>}
  </tbody>
</table>@if(!Model.Any()){<div class="empty-state"><i class="fas fa-procedures"></i><p>No patients yet.</p></div>}
</div></div>
