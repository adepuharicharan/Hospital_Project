@using HospitalEHR.Extensions
@{
    var sess     = Context.Session;
    var fullName = sess.GetFullName() ?? "User";
    var email    = sess.GetEmail()    ?? "";
    var roleStr  = sess.GetRole()     ?? "";
    var initials = string.Concat(fullName.Split(' ', StringSplitOptions.RemoveEmptyEntries).Take(2).Select(w => w[0])).ToUpper();
    var roleLabel = roleStr switch {
        "Admin"          => "Administrator",
        "Doctor"         => "Doctor",
        "Receptionist"   => "Receptionist",
        "LabTechnician"  => "Lab Technician",
        "Pharmacist"     => "Pharmacist",
        "BillingOfficer" => "Billing Officer",
        _                => roleStr
    };
    bool isAuth = sess.IsAuthenticated();
}
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8"/><meta name="viewport" content="width=device-width,initial-scale=1"/>
<title>@ViewData["Title"] — Hospital EHR</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>
<link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
</head>
<body>
@if (isAuth)
{
<header class="topbar">
  <button class="sidebar-toggle" id="sidebarToggle"><i class="fas fa-bars"></i></button>
  <a class="topbar-brand" href="/"><i class="fas fa-hospital-alt"></i><span>Hospital EHR</span></a>
  <div class="topbar-right">
    <span class="role-chip">@roleLabel</span>
    <div class="user-menu-wrap">
      <button class="user-btn" id="userMenuBtn">
        <div class="avatar">@initials</div>
        <span class="uname">@fullName</span>
        <i class="fas fa-chevron-down chev"></i>
      </button>
      <div class="user-dropdown" id="userDropdown">
        <div class="ud-header">
          <div class="ud-name">@fullName</div>
          <div class="ud-email">@email</div>
          <span class="ud-role">@roleLabel</span>
        </div>
        <a class="ud-item" asp-controller="Account" asp-action="ChangePassword"><i class="fas fa-key"></i> Change Password</a>
        <div class="ud-divider"></div>
        <form asp-controller="Account" asp-action="Logout" method="post">
          @Html.AntiForgeryToken()
          <button type="submit" class="ud-item danger"><i class="fas fa-sign-out-alt"></i> Sign Out</button>
        </form>
      </div>
    </div>
  </div>
</header>

<nav class="sidebar" id="sidebar">
  <div class="sidebar-inner">
    @if (roleStr == "Admin") {
    <div class="nav-section"><div class="nav-label">Overview</div>
      <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString()=="Admin"&&ViewContext.RouteData.Values["action"]?.ToString()=="Dashboard"?"active":"")" asp-controller="Admin" asp-action="Dashboard"><i class="fas fa-chart-pie"></i><span>Dashboard</span></a>
      <a class="nav-link" asp-controller="Admin" asp-action="AllPatients"><i class="fas fa-procedures"></i><span>All Patients</span></a>
      <a class="nav-link" asp-controller="Admin" asp-action="Reports"><i class="fas fa-chart-bar"></i><span>Reports</span></a>
    </div>
    <div class="nav-section"><div class="nav-label">Users</div>
      <a class="nav-link" asp-controller="Admin" asp-action="Users"><i class="fas fa-users"></i><span>Manage Users</span></a>
      <a class="nav-link" asp-controller="Admin" asp-action="CreateUser"><i class="fas fa-user-plus"></i><span>Add User</span></a>
    </div>
    }
    @if (roleStr == "Receptionist") {
    <div class="nav-section"><div class="nav-label">Reception</div>
      <a class="nav-link" asp-controller="Receptionist" asp-action="Dashboard"><i class="fas fa-chart-pie"></i><span>Dashboard</span></a>
      <a class="nav-link" asp-controller="Receptionist" asp-action="RegisterPatient"><i class="fas fa-user-plus"></i><span>Register Patient</span></a>
      <a class="nav-link" asp-controller="Receptionist" asp-action="PatientList"><i class="fas fa-list-ul"></i><span>Patient List</span></a>
    </div>
    }
    @if (roleStr == "Doctor") {
    <div class="nav-section"><div class="nav-label">Clinical</div>
      <a class="nav-link" asp-controller="Doctor" asp-action="Dashboard"><i class="fas fa-chart-pie"></i><span>Dashboard</span></a>
      <a class="nav-link" asp-controller="Doctor" asp-action="MyPatients"><i class="fas fa-procedures"></i><span>My Patients</span></a>
    </div>
    }
    @if (roleStr == "LabTechnician") {
    <div class="nav-section"><div class="nav-label">Laboratory</div>
      <a class="nav-link" asp-controller="LabTechnician" asp-action="Dashboard"><i class="fas fa-chart-pie"></i><span>Dashboard</span></a>
      <a class="nav-link" asp-controller="LabTechnician" asp-action="AllOrders"><i class="fas fa-flask"></i><span>All Orders</span></a>
    </div>
    }
    @if (roleStr == "Pharmacist") {
    <div class="nav-section"><div class="nav-label">Pharmacy</div>
      <a class="nav-link" asp-controller="Pharmacist" asp-action="Dashboard"><i class="fas fa-chart-pie"></i><span>Dashboard</span></a>
      <a class="nav-link" asp-controller="Pharmacist" asp-action="AllPrescriptions"><i class="fas fa-pills"></i><span>All Prescriptions</span></a>
    </div>
    }
    @if (roleStr == "BillingOfficer") {
    <div class="nav-section"><div class="nav-label">Billing</div>
      <a class="nav-link" asp-controller="BillingOfficer" asp-action="Dashboard"><i class="fas fa-chart-pie"></i><span>Dashboard</span></a>
      <a class="nav-link" asp-controller="BillingOfficer" asp-action="PatientList"><i class="fas fa-procedures"></i><span>Patient Bills</span></a>
      <a class="nav-link" asp-controller="BillingOfficer" asp-action="AllBills"><i class="fas fa-file-invoice-dollar"></i><span>All Bills</span></a>
    </div>
    }
    <div class="nav-section nav-bottom">
      <form asp-controller="Account" asp-action="Logout" method="post">
        @Html.AntiForgeryToken()
        <button type="submit" class="nav-link logout-btn"><i class="fas fa-sign-out-alt"></i><span>Sign Out</span></button>
      </form>
    </div>
  </div>
</nav>
<div class="sidebar-overlay" id="sidebarOverlay"></div>

<main class="main-content" id="mainContent">
  @if (TempData["Success"] != null) {
    <div class="toast toast-success"><i class="fas fa-check-circle"></i> @TempData["Success"]</div>
  }
  @if (TempData["Error"] != null) {
    <div class="toast toast-error"><i class="fas fa-exclamation-circle"></i> @TempData["Error"]</div>
  }
  @RenderBody()
</main>
}
else { @RenderBody() }
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/jquery.validate.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/4.0.0/jquery.validate.unobtrusive.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@RenderSection("Scripts", required: false)
</body>
</html>
