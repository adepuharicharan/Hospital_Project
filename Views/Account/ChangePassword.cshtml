@model ChangePasswordVM
@{ ViewData["Title"] = "Change Password"; }
<div class="page-header">
  <div class="ph-left">
    <div class="breadcrumb"><span>Account</span><i class="fas fa-chevron-right"></i><span>Change Password</span></div>
    <h1 class="ph-title">Change Password</h1>
  </div>
</div>
<div class="form-wrap">
  <div class="card">
    <div class="card-hdr"><i class="fas fa-key"></i> Update Password</div>
    <div class="card-body">
      <div class="info-banner"><i class="fas fa-info-circle"></i> Your password is stored as a one-way BCrypt hash and cannot be retrieved.</div>
      <form asp-action="ChangePassword" method="post">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="v-errors"></div>
        <div class="fg"><label class="fl">Current Password <span class="req">*</span></label>
          <div class="fi-wrap"><i class="fas fa-lock fi-icon"></i><input asp-for="CurrentPassword" class="fi" placeholder="Current password"/></div>
          <span asp-validation-for="CurrentPassword" class="ferr"></span></div>
        <div class="fg"><label class="fl">New Password <span class="req">*</span></label>
          <div class="fi-wrap"><i class="fas fa-lock fi-icon"></i><input asp-for="NewPassword" class="fi" placeholder="Min 8 chars: A-Z a-z 0-9 #"/></div>
          <span asp-validation-for="NewPassword" class="ferr"></span></div>
        <div class="fg"><label class="fl">Confirm New Password <span class="req">*</span></label>
          <div class="fi-wrap"><i class="fas fa-lock fi-icon"></i><input asp-for="ConfirmNewPassword" class="fi" placeholder="Repeat new password"/></div>
          <span asp-validation-for="ConfirmNewPassword" class="ferr"></span></div>
        <div class="btn-row">
          <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Update Password</button>
          <a href="/" class="btn btn-outline">Cancel</a>
        </div>
      </form>
    </div>
  </div>
</div>
@section Scripts { @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); } }
<h1>This is Change Password Page</h1>

