@model LoginVM
@{ Layout = null; ViewData["Title"] = "Login"; }
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8"/><meta name="viewport" content="width=device-width,initial-scale=1"/>
<title>Sign In — Hospital EHR</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>
<link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
</head>
<body class="login-body">
<div class="login-page">
  <div class="login-left">
    <div class="login-brand"><div class="brand-icon-lg"><i class="fas fa-hospital-alt"></i></div><span>Hospital EHR</span></div>
    <h2 class="login-headline">Patient Admission &amp;<br/>Health Record System</h2>
    <p class="login-tagline">A complete, role-driven healthcare platform covering registration, clinical care, lab, pharmacy, billing and discharge.</p>
    <div class="feature-pills">
      <div class="pill"><i class="fas fa-shield-alt"></i> BCrypt Auth</div>
      <div class="pill"><i class="fas fa-user-md"></i> 6 Role Dashboards</div>
      <div class="pill"><i class="fas fa-file-medical"></i> EHR Records</div>
      <div class="pill"><i class="fas fa-flask"></i> Lab Tracking</div>
      <div class="pill"><i class="fas fa-pills"></i> Pharmacy</div>
      <div class="pill"><i class="fas fa-file-invoice-dollar"></i> PDF Invoices</div>
    </div>
  </div>
  <div class="login-right">
    <div class="login-card">
      <h1 class="lc-title">Welcome Back</h1>
      <p class="lc-sub">Sign in to access your dashboard</p>
      <form asp-action="Login" asp-controller="Account" method="post">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="v-errors"></div>
        <div class="fg">
          <label class="fl">Email Address</label>
          <div class="fi-wrap"><i class="fas fa-envelope fi-icon"></i>
            <input asp-for="Email" class="fi" placeholder="you@hospital.com" autocomplete="email"/>
          </div>
          <span asp-validation-for="Email" class="ferr"></span>
        </div>
        <div class="fg">
          <label class="fl">Password</label>
          <div class="fi-wrap"><i class="fas fa-lock fi-icon"></i>
            <input asp-for="Password" class="fi" placeholder="Enter your password" autocomplete="current-password"/>
          </div>
          <span asp-validation-for="Password" class="ferr"></span>
        </div>
        <button type="submit" class="btn-login"><i class="fas fa-sign-in-alt"></i> Sign In</button>
      </form>
      <div class="creds-box">
        <div class="creds-hdr"><i class="fas fa-info-circle"></i> Demo Credentials</div>
        <div class="creds-grid">
          <div class="cr"><b>Admin</b> admin@hospital.com / Admin@123</div>
          <div class="cr"><b>Doctor 1</b> doctor1@hospital.com / Doctor@123</div>
          <div class="cr"><b>Receptionist</b> receptionist@hospital.com / Recep@123</div>
          <div class="cr"><b>Doctor 2</b> doctor2@hospital.com / Doctor@123</div>
          <div class="cr"><b>Lab Tech</b> lab1@hospital.com / Lab@12345</div>
          <div class="cr"><b>Pharmacist</b> pharmacist@hospital.com / Pharma@123</div>
          <div class="cr"><b>Billing</b> billing@hospital.com / Billing@123</div>
        </div>
      </div>
    </div>
  </div>
</div>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/jquery.validate.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/4.0.0/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>
