@model LabResultVM
@{ ViewData["Title"] = "Update Result"; }
<div class="page-header"><div class="ph-left"><div class="breadcrumb"><a asp-action="Dashboard">Lab</a><i class="fas fa-chevron-right"></i><span>Update Result</span></div><h1 class="ph-title">Enter Lab Result</h1></div></div>
<div class="form-wrap"><div class="card">
  <div class="card-hdr"><i class="fas fa-flask"></i> Test: @Model.TestName — @Model.PatientName</div>
  <div class="card-body">
    <form asp-action="UpdateResult" method="post">@Html.AntiForgeryToken()
      <input type="hidden" asp-for="LabOrderId"/><input type="hidden" asp-for="TestName"/><input type="hidden" asp-for="PatientName"/>
      <div asp-validation-summary="ModelOnly" class="v-errors"></div>
      <div class="form-grid">
        <div class="fg col-span-2"><label class="fl">Test Result <span class="req">*</span></label><textarea asp-for="Result" class="fi ta" rows="4" placeholder="Enter complete test result"></textarea><span asp-validation-for="Result" class="ferr"></span></div>
        <div class="fg col-span-2"><label class="fl">Lab Notes</label><textarea asp-for="LabNotes" class="fi ta" rows="2" placeholder="Additional notes"></textarea></div>
        <div class="fg"><label class="fl">Test Cost (Rs.) <span class="req">*</span></label><input asp-for="TestCost" type="number" step="0.01" class="fi" placeholder="0.00"/><span asp-validation-for="TestCost" class="ferr"></span></div>
      </div>
      <div class="btn-row mt2"><button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Submit Result</button><a asp-action="Dashboard" class="btn btn-outline">Cancel</a></div>
    </form>
  </div>
</div></div>
@section Scripts { @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); } }
