@model List<LabOrder>
@{ ViewData["Title"] = "Lab Dashboard"; }
<div class="page-header"><div class="ph-left"><h1 class="ph-title">Laboratory Dashboard</h1><p class="ph-sub">Pending &amp; in-progress orders</p></div></div>
<div class="stats-row">
  <div class="stat-card sc-blue"><div class="sc-icon"><i class="fas fa-list"></i></div><div class="sc-info"><div class="sc-val">@ViewBag.TotalOrders</div><div class="sc-lbl">Total Orders</div></div></div>
  <div class="stat-card sc-red"><div class="sc-icon"><i class="fas fa-clock"></i></div><div class="sc-info"><div class="sc-val">@ViewBag.Pending</div><div class="sc-lbl">Pending</div></div></div>
  <div class="stat-card sc-orange"><div class="sc-icon"><i class="fas fa-spinner"></i></div><div class="sc-info"><div class="sc-val">@ViewBag.InProgress</div><div class="sc-lbl">In Progress</div></div></div>
  <div class="stat-card sc-green"><div class="sc-icon"><i class="fas fa-check-circle"></i></div><div class="sc-info"><div class="sc-val">@ViewBag.Completed</div><div class="sc-lbl">Completed</div></div></div>
</div>
<div class="card"><div class="card-hdr"><i class="fas fa-flask"></i> Active Orders <a asp-action="AllOrders" class="btn btn-sm btn-outline ml-auto">View All</a></div>
<div class="table-wrap"><table class="dtable">
  <thead><tr><th>ID</th><th>Patient</th><th>Test</th><th>Doctor</th><th>Status</th><th>Ordered</th><th>Action</th></tr></thead>
  <tbody>
  @foreach(var o in Model){<tr>
    <td class="tid">#@o.LabOrderId</td><td class="fw6">@(o.Patient?.FullName??"—")</td><td>@o.TestName</td>
    <td class="tsm">@(o.OrderedByDoctor?.FullName??"—")</td>
    <td>@if(o.Status==TestStatus.Ordered){<span class="badge b-registered">Ordered</span>}else{<span class="badge b-admitted">In Progress</span>}</td>
    <td class="tsm tm">@o.OrderedAt.ToString("dd MMM yyyy")</td>
    <td><a asp-action="UpdateResult" asp-route-id="@o.LabOrderId" class="btn btn-sm btn-primary">Enter Result</a></td>
  </tr>}
  </tbody>
</table>@if(!Model.Any()){<div class="empty-state"><i class="fas fa-check-circle"></i><p>No pending orders.</p></div>}
</div></div>
